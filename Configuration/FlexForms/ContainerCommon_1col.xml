                                <numIndex index="4"><numIndex index="0">L</numIndex><numIndex index="1">mt-l</numIndex></numIndex>
                            </items>
                        </config>
                    </spacingTop>

                    <spacingBottom>
                        <label>Abstand unten</label>
                        <config>
                            <type>select</type><renderType>selectSingle</renderType>
                            <items>
                                <numIndex index="0"><numIndex index="0">–</numIndex><numIndex index="1"></numIndex></numIndex>
                                <numIndex index="1"><numIndex index="0">XS</numIndex><numIndex index="1">mb-xs</numIndex></numIndex>
