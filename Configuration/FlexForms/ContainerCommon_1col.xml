                                <numIndex index="0"><numIndex index="0">Transparent</numIndex><numIndex index="1"></numIndex></numIndex>
                                <numIndex index="1"><numIndex index="0">Hell</numIndex><numIndex index="1">bg-light</numIndex></numIndex>
                                <numIndex index="2"><numIndex index="0">Dunkel</numIndex><numIndex index="1">bg-dark</numIndex></numIndex>
                            </items>
                        </config>
                    </bgColor>

                    <classesContainer>
