# Keep header field visible for all container content types
TCEFORM.tt_content.header.types {
    container_one_column.disabled = 0
    container_two_columns.disabled = 0
    container_three_columns.disabled = 0
    container_section.disabled = 0
}

# Allow moving content into container columns via context menu
options.contextMenu.table.tt_content {
    disableItems := removeFromList(moveToColumn)
}
